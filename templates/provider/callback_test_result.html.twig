<div class="container-xl mt-4 mb-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">{{ __('Single Sign-on test result', 'singlesignon') }}</h3>
                <div class="card-actions">
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm"
                            id="sso-copy-all-tabs"
                            data-copy-success-label="{{ __('Copied', 'singlesignon') }}"
                            data-copy-error-label="{{ __('Copy failed', 'singlesignon') }}">
                        <i class="ti ti-copy"></i>
                        <span>{{ __('Copy all tabs', 'singlesignon') }}</span>
                    </button>
                </div>
            </div>
            <div class="card-body">
            <div class="text-muted mb-3">
                <strong>{{ __('Provider', 'singlesignon') }}:</strong>
                {{ provider.fields.name|default('') }} ({{ provider.fields.type|default('') }})
            </div>

            <ul class="nav nav-tabs" id="sso-test-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" type="button" data-sso-tab-target="#tab-resolved-fields">
                        {{ __('Resolved fields', 'singlesignon') }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" type="button" data-sso-tab-target="#tab-resource-owner">
                        {{ __('Resource Owner', 'singlesignon') }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" type="button" data-sso-tab-target="#tab-id-token">
                        {{ __('ID Token (JWT)', 'singlesignon') }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" type="button" data-sso-tab-target="#tab-active-mappings">
                        {{ __('Active mappings', 'singlesignon') }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" type="button" data-sso-tab-target="#tab-default-mappings">
                        {{ __('Default mappings', 'singlesignon') }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" type="button" data-sso-tab-target="#tab-context">
                        {{ __('Callback context', 'singlesignon') }}
                    </button>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-3" id="sso-test-tab-content">
                <div class="tab-pane active" id="tab-resolved-fields">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>{{ __('Type') }}</th>
                                    <th>{{ __('Value') }}</th>
                                    <th>{{ __('JSONPath', 'singlesignon') }}</th>
                                    <th>{{ __('Source') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for field_key, field_label in field_types %}
                                    {% set data = resolved_fields[field_key]|default({ value: null, jsonpath: null, source: null }) %}
                                    <tr>
                                        <td><code>{{ field_key }}</code> - {{ field_label }}</td>
                                        <td>
                                            {% if data.value is not null and data.value != '' %}
                                                {% set values = data.values|default([]) %}
                                                {% if values is iterable and values|length > 0 %}
                                                    <ul class="list-unstyled d-flex flex-wrap mb-0">
                                                        {% for item in values %}
                                                            <li class="me-1 mb-1"><code>{{ item }}</code></li>
                                                        {% endfor %}
                                                    </ul>
                                                {% else %}
                                                    <code>{{ data.value }}</code>
                                                {% endif %}
                                            {% else %}
                                                <span class="text-muted">{{ __('Not resolved', 'singlesignon') }}</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if data.jsonpath %}
                                                <code>{{ data.jsonpath }}</code>
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if data.source == 'provider' %}
                                                <span class="badge bg-blue-lt">{{ __('Provider mapping', 'singlesignon') }}</span>
                                            {% elseif data.source == 'provider (jwt)' %}
                                                <span class="badge bg-blue-lt">{{ __('Provider mapping (JWT)', 'singlesignon') }}</span>
                                            {% elseif data.source == 'default' %}
                                                <span class="badge bg-green-lt">{{ __('Default mapping', 'singlesignon') }}</span>
                                            {% elseif data.source == 'default (jwt)' %}
                                                <span class="badge bg-green-lt">{{ __('Default mapping (JWT)', 'singlesignon') }}</span>
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane" id="tab-resource-owner">
                    <pre class="mb-0" style="white-space: pre-wrap;">{{ resource_owner_pretty }}</pre>
                </div>

                <div class="tab-pane" id="tab-id-token">
                    {% if id_token_payload_pretty is empty %}
                        <div class="p-3 text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            {{ __('No ID token received or unable to parse.', 'singlesignon') }}
                        </div>
                    {% else %}
                        <pre class="mb-0" style="white-space: pre-wrap;">{{ id_token_payload_pretty }}</pre>
                    {% endif %}
                </div>

                <div class="tab-pane" id="tab-active-mappings">
                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>{{ __('Type') }}</th>
                                    <th>{{ __('JSONPath', 'singlesignon') }}</th>
                                    <th>{{ __('Order') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if active_mappings is empty %}
                                    <tr><td colspan="3" class="text-muted">{{ __('No active mappings found.', 'singlesignon') }}</td></tr>
                                {% else %}
                                    {% for row in active_mappings %}
                                        <tr>
                                            <td><code>{{ row.field_type }}</code></td>
                                            <td><code>{{ row.jsonpath }}</code></td>
                                            <td>{{ row.sort_order }}</td>
                                        </tr>
                                    {% endfor %}
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane" id="tab-default-mappings">
                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>{{ __('Type') }}</th>
                                    <th>{{ __('JSONPath', 'singlesignon') }}</th>
                                    <th>{{ __('Order') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if default_mappings is empty %}
                                    <tr><td colspan="3" class="text-muted">{{ __('No default mappings found for this provider type.', 'singlesignon') }}</td></tr>
                                {% else %}
                                    {% for row in default_mappings %}
                                        <tr>
                                            <td><code>{{ row.field_type }}</code></td>
                                            <td><code>{{ row.jsonpath }}</code></td>
                                            <td>{{ row.sort_order }}</td>
                                        </tr>
                                    {% endfor %}
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane" id="tab-context">
                    <pre class="mb-0" style="white-space: pre-wrap;">{{ callback_context_pretty }}</pre>
                </div>
            </div>
        </div>
    </div>
</div>

<textarea id="sso-copy-all-source" class="d-none">{{ copy_payload }}</textarea>
<script type="text/javascript" src="{{ call(['GlpiPlugin\\Singlesignon\\ToolboxPlugin', 'getPublicAssetUrl'], ['js/callback-test-result.js']) }}"></script>
