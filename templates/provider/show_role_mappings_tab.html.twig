{% set rows = mappings|length > 0 ? mappings : [{
   id: 0,
   remote_id: '',
   groups_id: 0
}] %}

<form method="post" action="{{ form_action }}">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}"/>
    <input type="hidden" name="plugin_singlesignon_providers_id" value="{{ provider_id }}"/>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">{{ __('Role mappings', 'singlesignon') }}</h3>
        </div>
        <div class="card-body">
            <p class="text-muted">
                {{ __('Map incoming IdP role/group claim values to existing GLPI groups.', 'singlesignon') }}
            </p>
            <table class="table table-striped table-hover align-middle" id="sso-role-mappings-table">
                <thead>
                    <tr>
                        <th>{{ __('Role / Group key', 'singlesignon') }}</th>
                        <th>{{ __('Group') }}</th>
                        <th class="text-center">{{ __('Actions') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for map in rows %}
                        {% set is_saved = (map.id|default(0)) > 0 %}
                        <tr data-row>
                            <td>
                                <input type="hidden" name="_role_mappings[{{ loop.index0 }}][id]" value="{{ map.id|default(0) }}"/>
                                <input type="text"
                                       class="form-control"
                                       name="_role_mappings[{{ loop.index0 }}][remote_id]"
                                       value="{{ map.remote_id|default('') }}"
                                       placeholder="admin"/>
                            </td>
                            <td>
                                <select class="form-select" name="_role_mappings[{{ loop.index0 }}][groups_id]">
                                    <option value="0">{{ __('Select a group') }}</option>
                                    {% for id, label in group_options %}
                                        <option value="{{ id }}" {% if id == map.groups_id %}selected{% endif %}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td class="text-center">
                                {% if is_saved %}
                                    <input type="checkbox"
                                           class="form-check-input"
                                           name="_role_mappings[{{ loop.index0 }}][_delete]"
                                           value="1"/>
                                {% else %}
                                    <button type="button" class="btn btn-outline-danger btn-sm" data-remove-row>
                                        <i class="ti ti-trash"></i> {{ __('Remove') }}
                                    </button>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            <button type="button" id="sso-add-role-mapping-row" class="btn btn-outline-secondary">
                <i class="ti ti-plus"></i> {{ __('Add') }}
            </button>
        </div>
        <div class="card-footer text-end">
            <button type="submit" name="update_role_mappings" class="btn btn-primary">
                {{ __('Save') }}
            </button>
        </div>
    </div>
</form>

<script type="text/javascript">
(() => {
    const table = document.getElementById('sso-role-mappings-table');
    const addBtn = document.getElementById('sso-add-role-mapping-row');
    if (!table || !addBtn) {
        return;
    }

    const groups = {{ group_options|json_encode|raw }};

    const buildOptions = () => {
        const defaultOption = `<option value="0">{{ __('Select a group')|e('js') }}</option>`;
        const groupOptions = Object.entries(groups)
            .map(([id, label]) => `<option value="${id}">${label}</option>`)
            .join('');
        return defaultOption + groupOptions;
    };

    const nextIndex = () => table.querySelectorAll('tbody tr[data-row]').length;

    addBtn.addEventListener('click', () => {
        const idx = nextIndex();
        const tr = document.createElement('tr');
        tr.setAttribute('data-row', '1');
        tr.innerHTML = `
            <td>
                <input type="hidden" name="_role_mappings[${idx}][id]" value="0"/>
                <input type="text" class="form-control" name="_role_mappings[${idx}][remote_id]" placeholder="admin"/>
            </td>
            <td>
                <select class="form-select" name="_role_mappings[${idx}][groups_id]">${buildOptions()}</select>
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-outline-danger btn-sm" data-remove-row>
                    <i class="ti ti-trash"></i> {{ __('Remove')|e('js') }}
                </button>
            </td>
        `;
        table.querySelector('tbody')?.appendChild(tr);
    });

    table.addEventListener('click', (event) => {
        const button = event.target.closest('[data-remove-row]');
        if (!button) {
            return;
        }
        const row = button.closest('tr[data-row]');
        if (row) {
            row.remove();
        }
    });
})();
</script>
