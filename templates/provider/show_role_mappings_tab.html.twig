{% set rows = mappings|length > 0 ? mappings : [{
   id: 0,
   remote_id: '',
   groups_id: 0,
   is_active: 1
}] %}

<form method="post" action="{{ form_action }}">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}"/>
    <input type="hidden" name="plugin_singlesignon_providers_id" value="{{ provider_id }}"/>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">{{ __('Role mappings', 'singlesignon') }}</h3>
        </div>
        <div class="card-body">
            <p class="text-muted">
                {{ __('Map incoming IdP role/group claim values to existing GLPI groups.', 'singlesignon') }}
            </p>
            <table class="table table-striped table-hover align-middle"
                   id="sso-role-mappings-table"
                   data-restore-label="{{ __('Restore') }}">
                <thead>
                    <tr>
                        <th>{{ __('Role / Group key', 'singlesignon') }}</th>
                        <th>{{ __('Group') }}</th>
                        <th class="text-center">{{ __('Active') }}</th>
                        <th class="text-center">{{ __('Actions') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for map in rows %}
                        {% set is_saved = (map.id|default(0)) > 0 %}
                        <tr data-row data-saved="{{ is_saved ? '1' : '0' }}">
                            <td>
                                <input type="hidden" name="_role_mappings[{{ loop.index0 }}][id]" value="{{ map.id|default(0) }}"/>
                                {% if is_saved %}
                                    <input type="hidden" class="sso-delete-flag" name="_role_mappings[{{ loop.index0 }}][_delete]" value="0"/>
                                {% endif %}
                                <input type="text"
                                       class="form-control"
                                       name="_role_mappings[{{ loop.index0 }}][remote_id]"
                                       value="{{ map.remote_id|default('') }}"
                                       placeholder="admin"/>
                            </td>
                            <td>
                                {{ call('Dropdown::show', ['Group', {
                                    name: '_role_mappings[' ~ loop.index0 ~ '][groups_id]',
                                    value: map.groups_id|default(0),
                                    display: false,
                                    width: '100%',
                                    rand: 'sg_' ~ loop.index0
                                }])|raw }}
                            </td>
                            <td class="text-center">
                                <input type="checkbox"
                                       class="form-check-input"
                                       name="_role_mappings[{{ loop.index0 }}][is_active]"
                                       value="1"
                                       {% if map.is_active|default(1) %}checked{% endif %}/>
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-outline-danger btn-sm" data-remove-row>
                                    <i class="ti ti-trash"></i> {{ __('Remove') }}
                                </button>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            <button type="button" id="sso-add-role-mapping-row" class="btn btn-outline-secondary">
                <i class="ti ti-plus"></i> {{ __('Add') }}
            </button>
        </div>
        <div class="card-footer text-end">
            <button type="submit" name="update_role_mappings" class="btn btn-primary">
                <i class="ti ti-device-floppy"></i>
                <span>{{ _x('button', 'Save') }}</span>
            </button>
        </div>
    </div>
</form>

<script type="text/javascript">
(() => {
    const table = document.getElementById('sso-role-mappings-table');
    const addBtn = document.getElementById('sso-add-role-mapping-row');
    if (!table || !addBtn) {
        return;
    }

    const providerId = {{ provider_id|json_encode|raw }};
    const formUrl = {{ form_action|json_encode|raw }};

    const nextIndex = () => table.querySelectorAll('tbody tr[data-row]').length;

    addBtn.addEventListener('click', async () => {
        const idx = nextIndex();
        try {
            const url = `${formUrl}?action=new_row&provider_id=${encodeURIComponent(providerId)}&idx=${encodeURIComponent(idx)}`;
            const response = await fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            if (!response.ok) {
                return;
            }
            const html = await response.text();
            const tbody = table.querySelector('tbody');
            if (tbody) {
                const range = document.createRange();
                range.selectNodeContents(tbody);
                const fragment = range.createContextualFragment(html);
                tbody.appendChild(fragment);
            }
        } catch (e) {
            console.error('Failed to add role mapping row', e);
        }
    });
})();
</script>

<script type="text/javascript" src="{{ call(['GlpiPlugin\\Singlesignon\\ToolboxPlugin', 'getPublicAssetUrl'], ['js/mapping-row-actions.js']) }}"></script>
