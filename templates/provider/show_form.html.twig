{% import 'components/form/fields_macros.html.twig' as fields %}
{% import 'components/form/basic_inputs_macros.html.twig' as inputs %}

{% set slo_supported_types = [] %}
{% for type, label in call(['GlpiPlugin\\Singlesignon\\Provider', 'getTypes'], []) %}
  {% if call(['GlpiPlugin\\Singlesignon\\Provider', 'getDefault'], [type, 'url_slo']) is not empty %}
    {% set slo_supported_types = slo_supported_types|merge([type]) %}
  {% endif %}
{% endfor %}

{% set sso_hidden_class = provider.fields.type|default('generic') != 'generic' ? 'd-none' : '' %}
{% set sso_azure_hidden_class = provider.fields.type != 'azure' ? 'd-none' : '' %}
{% set sso_preset_slo_hidden_class = provider.fields.type|default('generic') in slo_supported_types ? '' : 'd-none' %}
{% set picture_style = 'max-width: 100px; max-height: 100px; background-image: linear-gradient(45deg, #b0b0b0 25%, transparent 25%), linear-gradient(-45deg, #b0b0b0 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #b0b0b0 75%), linear-gradient(-45deg, transparent 75%, #b0b0b0 75%); background-size: 10px 10px; background-position: 0 0, 0 5px, 5px -5px, -5px 0px;' %}

{% set _tip_extra = call('nl2br', [call('sprintf', [
   __('Allows you to specify custom parameters for the SSO provider %1$s. Example: %2$s to force login or %3$s to force account selection (supported URL settings may vary by provider). You can specify additional parameters with the "&" delimiter.', 'singlesignon'),
   '<strong>' ~ __('Authorize URL', 'singlesignon') ~ '</strong>',
   '<code>prompt=login</code>',
   '<code>prompt=select_account</code>'
])]) %}
{% set _tip_domains = call('nl2br', [__('Provide a list of domains allowed to log in through this provider (separated by commas, no spaces) (optional).', 'singlesignon')]) %}
{% set _tip_photo_sync = call('nl2br', [__('Choose when user avatars should be synchronized during login.', 'singlesignon')]) %}
{% set _tip_resource_owner_auth = call('nl2br', [__('Controls how Authorization header is built for Resource Owner Details requests.', 'singlesignon')]) %}
{% set _tip_picture_auth = call('nl2br', [__('Controls how Authorization header is built for avatar download requests.', 'singlesignon')]) %}
{% set _tip_custom_headers = call('nl2br', [__('One header per line (format: Header-Name: value). Supported placeholders: <token> and <access_token>. Example: api-key: <token>', 'singlesignon')]) %}
{% set _tip_ssl_verify_host = call('nl2br', [__('Verify that the server certificate matches the hostname (recommended). Disable only for testing or self-signed certificates.', 'singlesignon')]) %}
{% set _tip_ssl_verify_peer = call('nl2br', [__('Verify the server certificate against trusted CAs (recommended). Disable only for testing or self-signed certificates.', 'singlesignon')]) %}
{% set _tip_is_default = call('nl2br', [__('When enabled, users who visit the login page will be automatically redirected to this provider\'s authentication page. To bypass the redirect and access the standard GLPI login form, add noAUTO=1 to the login URL.', 'singlesignon')]) %}
{% set _tip_split_domain = call('nl2br', [__('When enabled, the domain part (everything after @) is stripped from the user\'s login name. Useful when the IdP returns an email address as the login and GLPI usernames do not include the domain.', 'singlesignon')]) %}
{% set _tip_split_name = call('nl2br', [__('When enabled, the full name returned by the IdP is automatically split into first name and last name fields.', 'singlesignon')]) %}
{% set _tip_azure_endpoint = call('nl2br', [call('sprintf', [__('Use %1$s to allow login from any work, school, or personal account. If you specify a custom tenant (Example: %2$s), only users belonging to that specific tenant will be able to log in.', 'singlesignon'), '<code>common</code>', '<code>example.com</code>'])]) %}
{% set _tip_slo = call('nl2br', [__('URL used by the Identity Provider to receive logout requests (Single Logout, SLO). If provided, users logging out of GLPI will also be logged out from the Identity Provider.', 'singlesignon')]) %}
{% set _tip_use_slo = call('nl2br', [__('Enables the usage of the predefined Single Logout URL (SLO) for this Identity Provider.', 'singlesignon')]) %}

{% set type_on_change %}
    var _value = this.options[this.selectedIndex].value; 
    
    // Handle Generic SSO URL
    var isGeneric = _value === "generic";
    $(".sso_url").toggleClass("d-none", !isGeneric).toggle(isGeneric);

    // Handle Azure 
    var isAzure = _value === "azure";
    $(".sso_azure").toggleClass("d-none", !isAzure).toggle(isAzure);
    
    // Handle Preset SLO
    var slo_types = {{ slo_supported_types|json_encode|raw }};
    var isPresetSlo = slo_types.includes(_value);
    $(".sso_preset_slo").toggleClass("d-none", !isPresetSlo).toggle(isPresetSlo);
{% endset %}
{% set field_opts = {
    align_label_right: true,
    field_class: 'col-12 col-xxl-6',
    label_class: 'col-xxl-4',
    input_class: 'col-xxl-8'
} %}

<form method="post" action="{{ form_action }}">
<input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}"/>
{% if provider_id %}
    <input type="hidden" name="id" value="{{ provider_id }}"/>
{% endif %}

<div id="sso-provider-modern-form" class="row text-start">
    <div class="col-12">
        <div class="hr-text my-3">{{ __('General') }}</div>
    </div>

    {{ fields.textField('name', provider.fields.name|default(''), __('Name'), field_opts) }}
    {{ fields.textareaField('comment', provider.fields.comment|default(''), __('Comments'), {
        rows: 5,
        enable_richtext: false,
        enable_fileupload: false
    }|merge(field_opts)) }}

    {% set type_rand = random() %}
    {% set type_field %}
        {{ call(['GlpiPlugin\\Singlesignon\\Provider', 'dropdownType'], ['type', {
            value: provider.fields.type|default('generic'),
            on_change: type_on_change,
            width: '100%',
            display: false,
            rand: type_rand
        }])|raw }}
    {% endset %}
    {{ fields.htmlField('type', type_field, __('SSO Type', 'singlesignon'), field_opts|merge({id: 'dropdown_type' ~ type_rand})) }}
    {{ fields.sliderField('is_active', provider.fields.is_active|default(0), __('Active'), field_opts) }}

    {{ fields.textField('client_id', provider.fields.client_id|default(''), __('Client ID', 'singlesignon'), field_opts) }}
    {{ fields.passwordField('client_secret', provider.fields.client_secret|default(''), __('Client Secret', 'singlesignon'), {
        is_disclosable: true,
        is_copyable: false
    }|merge(field_opts)) }}
    {{ fields.textField('azure_endpoint', call([provider, 'getAzureEndpoint'], []), __('Azure Endpoint', 'singlesignon'), {
        add_field_class: 'sso_azure ' ~ sso_azure_hidden_class,
        helper: _tip_azure_endpoint
    }|merge(field_opts)) }}
    {{ fields.nullField({
        field_class: 'col-12 col-xxl-6 sso_azure ' ~ sso_azure_hidden_class
    }) }}

    <div class="col-12">
        <div class="hr-text my-3">{{ __('OAuth URLs and HTTP', 'singlesignon') }}</div>
    </div>

    {{ fields.textField('scope', call([provider, 'getScope'], []), __('Scope', 'singlesignon'), field_opts) }}
    {{ fields.textField('extra_options', provider.fields.extra_options|default(''), __('Extra Options', 'singlesignon'), {
        helper: _tip_extra
    }|merge(field_opts)) }}

    {{ fields.urlField('url_authorize', call([provider, 'getAuthorizeUrl'], []), __('Authorize URL', 'singlesignon'), {
        add_field_class: 'sso_url ' ~ sso_hidden_class
    }|merge(field_opts)) }}
    {{ fields.urlField('url_access_token', call([provider, 'getAccessTokenUrl'], []), __('Access Token URL', 'singlesignon'), {
        add_field_class: 'sso_url ' ~ sso_hidden_class
    }|merge(field_opts)) }}
    {{ fields.urlField('url_resource_owner_details', call([provider, 'getResourceOwnerDetailsUrl'], []), __('Resource Owner Details URL', 'singlesignon'), {
        add_field_class: 'sso_url ' ~ sso_hidden_class
    }|merge(field_opts)) }}
    {{ fields.nullField({
        field_class: 'col-12 col-xxl-6 sso_url ' ~ sso_hidden_class
    }) }}

    {{ fields.dropdownArrayField('resource_owner_auth_type', provider.fields.resource_owner_auth_type|default('bearer'), call(['GlpiPlugin\\Singlesignon\\Provider', 'getAuthorizationTypes'], []), __('Resource Owner Authorization', 'singlesignon'), {
        helper: _tip_resource_owner_auth
    }|merge(field_opts)) }}
    {{ fields.textareaField('resource_owner_custom_headers', provider.fields.resource_owner_custom_headers|default(''), __('Resource Owner Custom Headers', 'singlesignon'), {
        rows: 3,
        enable_richtext: false,
        enable_fileupload: false,
        helper: _tip_custom_headers
    }|merge(field_opts)) }}

    {{ fields.sliderField('ssl_verify_host', provider.fields.ssl_verify_host|default(1), __('SSL verify host', 'singlesignon'), {
        helper: _tip_ssl_verify_host
    }|merge(field_opts)) }}
    {{ fields.sliderField('ssl_verify_peer', provider.fields.ssl_verify_peer|default(1), __('SSL verify peer', 'singlesignon'), {
        helper: _tip_ssl_verify_peer
    }|merge(field_opts)) }}

    {{ fields.urlField('url_slo', provider.fields.url_slo|default(''), __('Single Logout URL', 'singlesignon'), {
        add_field_class: 'sso_url ' ~ sso_hidden_class,
        helper: _tip_slo
    }|merge(field_opts)) }}
    {% set _use_slo = provider.fields.url_slo|default('') is not empty ? 1 : 0 %}
    {{ fields.sliderField('_use_slo', _use_slo, __('Use SLO', 'singlesignon'), {
        add_field_class: 'sso_preset_slo ' ~ sso_preset_slo_hidden_class,
        helper: _tip_use_slo
    }|merge(field_opts)) }}
    {{ fields.nullField({
        field_class: 'col-12 col-xxl-6'
    }) }}

    {{ fields.nullField({
        field_class: 'col-12 col-xxl-6 sso_url ' ~ sso_hidden_class
    }) }}

    <div class="col-12">
        <div class="hr-text my-3">{{ __('Login behavior', 'singlesignon') }}</div>
    </div>

    {{ fields.sliderField('is_default', provider.fields.is_default|default(0), __('IsDefault', 'singlesignon'), {
        helper: _tip_is_default
    }|merge(field_opts)) }}
    {{ fields.sliderField('popup', provider.fields.popup|default(0), __('PopupAuth', 'singlesignon'), field_opts) }}
    {{ fields.sliderField('split_domain', provider.fields.split_domain|default(0), __('SplitDomain', 'singlesignon'), {
        helper: _tip_split_domain
    }|merge(field_opts)) }}
    {{ fields.textField('authorized_domains', provider.fields.authorized_domains|default(''), __('AuthorizedDomains', 'singlesignon'), {
        helper: _tip_domains
    }|merge(field_opts)) }}
    {{ fields.sliderField('use_email_for_login', provider.fields.use_email_for_login|default(0), __('Use Email as Login', 'singlesignon'), field_opts) }}
    {{ fields.sliderField('split_name', provider.fields.split_name|default(0), __('Split Name', 'singlesignon'), {
        helper: _tip_split_name
    }|merge(field_opts)) }}

    <div class="col-12">
        <div class="hr-text my-3">{{ __('Registration', 'singlesignon') }}</div>
    </div>

    {{ fields.sliderField('auto_register', provider.fields.auto_register|default(0), __('Allow automatic registration', 'singlesignon'), field_opts) }}
    {{ fields.sliderField('registration_preview', provider.fields.registration_preview|default(0), __('Confirm registration before creating account', 'singlesignon'), field_opts) }}
    {{ fields.dropdownField(
        'Entity',
        'default_entities_id',
        provider.fields['default_entities_id']|default(0),
        __('Default entity for users', 'singlesignon'),
        field_opts|merge({ display_emptychoice: true })
    ) }}
    {{ fields.nullField({
        field_class: 'col-12 col-xxl-6'
    }) }}

    {{ fields.dropdownField(
        'Profile',
        'default_profiles_id',
        provider.fields['default_profiles_id']|default(0),
        __('Default profile when GLPI has no default', 'singlesignon'),
        field_opts|merge({ display_emptychoice: true })
    ) }}
    {{ fields.sliderField('default_profiles_id_is_recursive', provider.fields.default_profiles_id_is_recursive|default(0), __('Recursive', 'singlesignon'), field_opts) }}

    <div class="col-12">
        <div class="hr-text my-3">{{ __('User photo synchronization', 'singlesignon') }}</div>
    </div>

    {{ fields.dropdownArrayField('user_photo_sync_mode', provider.fields.user_photo_sync_mode|default(0), call(['GlpiPlugin\\Singlesignon\\Provider', 'getPhotoSyncModes'], []), __('Synchronization mode', 'singlesignon'), {
        helper: _tip_photo_sync
    }|merge(field_opts)) }}
    {{ fields.dropdownArrayField('resource_owner_picture_auth_type', provider.fields.resource_owner_picture_auth_type|default('bearer'), call(['GlpiPlugin\\Singlesignon\\Provider', 'getAuthorizationTypes'], []), __('Photo Authorization', 'singlesignon'), {
        helper: _tip_picture_auth
    }|merge(field_opts)) }}
    {{ fields.textareaField('resource_owner_picture_custom_headers', provider.fields.resource_owner_picture_custom_headers|default(''), __('Photo Custom Headers', 'singlesignon'), {
        rows: 3,
        enable_richtext: false,
        enable_fileupload: false,
        helper: _tip_custom_headers
    }|merge(field_opts)) }}

    <div class="col-12">
        <div class="hr-text my-3">{{ __('Personalization') }}</div>
    </div>

    {% set bgcolor_extra = '<label class="mb-0 d-flex justify-content-end align-items-center" style="cursor: pointer;">' ~ call('Html::getCheckbox', [{title: __('Clear'), name: '_blank_bgcolor', class: 'mt-0', checked: (provider.fields.bgcolor|default('')) == ''}])|raw ~ '<span class="ms-1">' ~ __('Clear')|e ~ '</span></label>' %}
    {% set color_extra = '<label class="mb-0 d-flex justify-content-end align-items-center" style="cursor: pointer;">' ~ call('Html::getCheckbox', [{title: __('Clear'), name: '_blank_color', class: 'mt-0', checked: (provider.fields.color|default('')) == ''}])|raw ~ '<span class="ms-1">' ~ __('Clear')|e ~ '</span></label>' %}
    {{ fields.colorField('bgcolor', provider.fields.bgcolor|default(''), __('Background color'), {
        add_field_html: bgcolor_extra,
        inline_add_field_html: true
    }|merge(field_opts)) }}
    {{ fields.colorField('color', provider.fields.color|default(''), __('Color'), {
        add_field_html: color_extra,
        inline_add_field_html: true
    }|merge(field_opts)) }}

    {% if provider.fields.picture|default('') is not empty %}
        {% set picture_field = call('Html::image', [call(['GlpiPlugin\\Singlesignon\\ToolboxPlugin', 'getPictureUrl'], [provider.fields.picture]), {style: picture_style, class: 'picture_square'}])|raw %}
        {% set picture_extra = '<label class="mb-0 d-flex justify-content-end align-items-center" style="cursor: pointer;">' ~ call('Html::getCheckbox', [{title: __('Clear'), name: '_blank_picture', class: 'mt-0'}])|raw ~ '<span class="ms-1">' ~ __('Clear')|e ~ '</span></label>' %}
    {% else %}
        {% set picture_field = inputs.file('picture', null, {onlyimages: true}) %}
        {% set picture_extra = '' %}
    {% endif %}
    {{ fields.htmlField('picture', picture_field, __('Picture'), {
        field_class: 'col-12 col-xxl-6',
        label_class: field_opts.label_class,
        input_class: field_opts.input_class,
        add_field_html: picture_extra,
        inline_add_field_html: true
    }) }}
    {{ fields.nullField({
        field_class: 'col-12 col-xxl-6'
    }) }}

<script type="text/javascript">
$("[name=bgcolor]").on("change", function () {
   $("[name=_blank_bgcolor]").prop("checked", false).attr("checked", false);
});
$("[name=color]").on("change", function () {
   $("[name=_blank_color]").prop("checked", false).attr("checked", false);
});
</script>

{% if provider_id %}
    {% set cb_path = call(['GlpiPlugin\\Singlesignon\\ToolboxPlugin', 'getCallbackUrl'], [provider_id]) %}
    {% set cb_full = call(['GlpiPlugin\\Singlesignon\\ToolboxPlugin', 'getBaseURL'], []) ~ cb_path %}
    {% set cb_link = '<a id="singlesignon_callbackurl" href="' ~ cb_full|e('html_attr') ~ '" data-url="' ~ cb_path|e('html_attr') ~ '">' ~ cb_full|e ~ '</a>' %}
    <div class="col-12 mt-2">
        <div class="hr-text my-3">{{ __('Test') }}</div>
    </div>
    {{ fields.htmlField('callback_url', cb_link, __('Callback URL', 'singlesignon'), {full_width: true}|merge(field_opts)) }}
{% endif %}
</div>

<div class="card-footer mx-n2 d-flex gap-2">
    {% if provider_id %}
        <button type="submit" name="update" value="1" class="btn btn-primary ms-auto">
            <i class="ti ti-device-floppy"></i>
            <span>{{ _x('button', 'Save') }}</span>
        </button>
        <button type="button" name="test_singlesignon" class="btn btn-outline-secondary">
            <i class="ti ti-plug-connected"></i>
            <span>{{ __('Test Single Sign-on', 'singlesignon') }}</span>
        </button>
        <button type="submit" name="delete" value="1" class="btn btn-outline-danger">
            <i class="ti ti-trash"></i>
            <span>{{ __('Put in trashbin') }}</span>
        </button>
    {% else %}
        <button type="submit" name="add" value="1" class="btn btn-primary ms-auto">
            <i class="ti ti-plus"></i>
            <span>{{ _x('button', 'Add') }}</span>
        </button>
    {% endif %}
</div>
</form>
