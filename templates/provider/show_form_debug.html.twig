<table class="tab_cadre_fixe">
    <tr><th>{{ title_json }}</th></tr>
    <tr><td class="center">
        <button type="button" class="btn btn-secondary" onclick="document.getElementById('glpi-singlesignon-json-debug').click();flashIconButton(this, 'btn btn-success', 'ti ti-check', 1500);">
            <i class="far fa-copy me-2"></i>{{ copy_label }}
        </button>
    </td></tr>
    <tr><td>
        <div class="copy_to_clipboard_wrapper">
            <textarea cols="132" rows="50" style="border:1" name="json" id="glpi-singlesignon-json-debug" class="form-control">{{ json_pretty|e('html') }}</textarea>
        </div>
    </td></tr>
</table>
