 #
 # Shared Remove / Restore behaviour for mapping table rows.
 #
 # Include this partial once per tab that has [data-remove-row] buttons inside
 # <tr data-row data-saved="0|1"> rows.
 #
 # Saved rows (data-saved="1") are marked for deletion (opacity fade) instead
 # of being removed from the DOM immediately; clicking the resulting "Restore"
 # button cancels the deletion.  Unsaved rows are removed from the DOM.
 #
 # A per-page guard (window._ssoMappingRowActionsRegistered) prevents the
 # document-level listener from being registered more than once even when
 # multiple tabs include this partial on the same page load.
 #}

<script type="text/javascript">
(function () {
    if (window._ssoMappingRowActionsRegistered) {
        return;
    }
    window._ssoMappingRowActionsRegistered = true;

    const REMOVE_LABEL  = '<i class="ti ti-trash"><\/i> {{ __('Remove')|e('js') }}';
    const RESTORE_LABEL = '<i class="ti ti-rotate"><\/i> {{ __('Restore')|e('js') }}';

    document.addEventListener('click', function (event) {
        const button = event.target.closest('[data-remove-row]');
        if (!button) {
            return;
        }
        const row = button.closest('tr[data-row]');
        if (!row) {
            return;
        }

        if (button.dataset.undo) {
            // Restore: undo pending deletion
            const deleteFlag = row.querySelector('.sso-delete-flag');
            if (deleteFlag) {
                deleteFlag.value = '0';
            }
            row.style.opacity = '';
            row.style.pointerEvents = '';
            button.style.pointerEvents = '';
            button.style.opacity = '';
            delete button.dataset.undo;
            button.classList.remove('btn-warning');
            button.classList.add('btn-outline-danger');
            button.innerHTML = REMOVE_LABEL;
            return;
        }

        const isSaved = row.dataset.saved === '1';
        if (isSaved) {
            // Mark for deletion on next save
            const deleteFlag = row.querySelector('.sso-delete-flag');
            if (deleteFlag) {
                deleteFlag.value = '1';
            }
            row.style.opacity = '0.4';
            row.style.pointerEvents = 'none';
            button.style.pointerEvents = 'auto';
            button.style.opacity = '1';
            button.dataset.undo = '1';
            button.classList.remove('btn-outline-danger');
            button.classList.add('btn-warning');
            button.innerHTML = RESTORE_LABEL;
        } else {
            row.remove();
        }
    });
}());
</script>
