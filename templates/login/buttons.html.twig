<div class="singlesignon-login">
    <h3 class="singlesignon-login-title text-center">{{ __('Single Sign-on', 'singlesignon') }}</h3>
    <div class="singlesignon-login-buttons d-grid gap-2" role="list">
        {% for button in buttons %}
            <a class="btn singlesignon-login-button {{ button.picture ? 'singlesignon-login-button--picture' : 'singlesignon-login-button--icon' }}" href="{{ button.href }}"
               {% if button.style %}style="{{ button.style }}"{% endif %}
               {% if button.popup %}data-singlesignon-popup="true"{% endif %}
               role="listitem">
                <span class="singlesignon-login-visual" aria-hidden="true">
                {% if button.picture %}
                    <img src="{{ button.picture }}" alt="" class="singlesignon-login-picture"/>
                {% else %}
                    <i class="ti ti-lock"></i>
                {% endif %}
                </span>
                <span class="singlesignon-login-label">{{ button.label }}</span>
                <span class="singlesignon-login-arrow" aria-hidden="true">
                    <i class="ti ti-chevron-right"></i>
                </span>
            </a>
        {% endfor %}
    </div>
    {% if show_remember %}
        {# Session preference below primary OAuth actions (common UX pattern). #}
        <div class="singlesignon-login-remember" role="group" aria-label="{{ __('Session options', 'singlesignon') }}">
            <div class="singlesignon-login-remember-inner">
                <span class="singlesignon-login-remember-icon" aria-hidden="true">
                    <i class="ti ti-shield-check"></i>
                </span>
                <label class="singlesignon-login-remember-label form-check mb-0" for="singlesignon_login_remember">
                    <input type="checkbox" class="form-check-input mt-0" id="singlesignon_login_remember" data-singlesignon-remember-toggle="true" {{ remember_default ? 'checked' : '' }}/>
                    <span class="form-check-label">
                        <span class="singlesignon-login-remember-title">{{ __('Remember me') }}</span>
                        <small class="singlesignon-login-remember-hint text-muted">{{ __('Stay signed in on this browser until you sign out.', 'singlesignon') }}</small>
                    </span>
                </label>
            </div>
        </div>
    {% endif %}
</div>
{# OAuth popup: anchors with data-singlesignon-popup #}
<script>
(function () {
    const applyRememberToOAuthLinks = () => {
        const checkbox = document.getElementById('singlesignon_login_remember');
        if (!checkbox) {
            return;
        }
        const enabled = checkbox.checked;
        document.querySelectorAll('a.singlesignon-login-button[href]').forEach((anchor) => {
            let href = anchor.getAttribute('href') || '';
            try {
                const url = new URL(href, window.location.origin);
                if (enabled) {
                    url.searchParams.set('remember', '1');
                } else {
                    url.searchParams.delete('remember');
                }
                const qs = url.search ? url.search : '';
                anchor.setAttribute('href', url.pathname + qs + url.hash);
            } catch (e) {
                if (enabled) {
                    href += (href.indexOf('?') === -1 ? '?' : '&') + 'remember=1';
                } else {
                    href = href.replace(/([?&])remember=1(&|$)/, '$1').replace(/\?$/, '').replace(/&$/, '');
                }
                anchor.setAttribute('href', href);
            }
        });
    };

    const rememberCheckbox = document.getElementById('singlesignon_login_remember');
    if (rememberCheckbox) {
        applyRememberToOAuthLinks();
        rememberCheckbox.addEventListener('change', applyRememberToOAuthLinks);
    }

    document.addEventListener('click', (event) => {
        const trigger = event.target.closest('[data-singlesignon-popup="true"]');
        if (!trigger) {
            return;
        }
        event.preventDefault();
        const width = 600;
        const height = 800;
        const left = (window.innerWidth / 2) - (width / 2);
        const top = (window.innerHeight / 2) - (height / 2);
        let url = trigger.getAttribute('href');
        if (url.indexOf('?') === -1) {
            url += '?popup=1';
        } else {
            url += '&popup=1';
        }
        window.open(url, 'singlesignon', `width=${width},height=${height},left=${left},top=${top}`);
    });

    // Close the popup if it is opened in a new window
    if (window.opener) {
        window.opener.location=window.location;
        window.close();
    }

})();
</script>
