{% do call(['Html', 'nullHeader'], [__('Login', 'singlesignon'), header_back_url]) %}
<div class="center b">{{ __('User not authorized to connect in GLPI', 'singlesignon') }}<br><br>
<a href="{{ retry_url|e('html') }}" class="singlesignon">{{ __('Log in again', 'singlesignon') }}</a></div>
<script type="text/javascript">
   if (window.opener) {
      $(".singlesignon").on("click", function (e) {
         e.preventDefault();
         window.opener.location = $(this).attr("href");
         window.focus();
         window.close();
      });
   }
</script>
{% do call(['Html', 'nullFooter']) %}
