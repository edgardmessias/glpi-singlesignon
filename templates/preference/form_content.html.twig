{{ call('Html::hidden', ['user_id', {value: user_id}])|raw }}

<div class="center singlesignon-preference" id="tabsbody">
    <div class="singlesignon-preference-grid">
        {% if linked_accounts is not empty %}
            <section class="singlesignon-preference-card">
                <h3 class="singlesignon-preference-title">{{ __('Linked accounts', 'singlesignon') }}</h3>
                <div class="singlesignon-preference-linked-list">
                    {% for row in linked_accounts %}
                        <label class="singlesignon-preference-linked-item">
                            <span class="singlesignon-preference-linked-text">
                                {{ row.provider_name|e }}
                                <small>ID: {{ row.remote_id|e }}</small>
                            </span>
                            <span class="singlesignon-preference-linked-remove">
                                {{ call('Html::getCheckbox', [{title: __('Clear'), name: '_remove_sso[]', value: row.pu_id}])|raw }}
                                <span>{{ __('Clear') }}</span>
                            </span>
                        </label>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        <section class="singlesignon-preference-card">
            <h3 class="singlesignon-preference-title">{{ __('Single Sign-on Provider', 'singlesignon') }}</h3>
            <div class="singlesignon-preference-providers">
                {{ provider_buttons_html|raw }}
            </div>
        </section>
    </div>

    {% if canedit %}
        <div class="singlesignon-preference-actions">
            <input type="submit" name="update" class="btn btn-primary" value="{{ call('_sx', ['button', 'Save'])|e('html_attr') }}">
        </div>
    {% endif %}
</div>

<script type="text/javascript">
$(document).ready(function () {
    $(document).on("click", ".singlesignon.oauth-login, [data-singlesignon-popup=\"true\"]", function (e) {
        e.preventDefault();
        var url = $(this).attr("href");
        var left = ($(window).width() / 2) - (600 / 2);
        var top = ($(window).height() / 2) - (800 / 2);
        var newWindow = window.open(url, "singlesignon", "width=600,height=800,left=" + left + ",top=" + top);
        if (window.focus) {
            newWindow.focus();
        }
    });
});
</script>
